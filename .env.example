# Authentication — pick ONE of the two options below.
#
# Option A — Token / machine auth (best for unattended automation)
#   A1: Static API token (simplest)
SPROUT_API_TOKEN=
#   A2: OAuth machine-to-machine (all three required)
SPROUT_CLIENT_ID=
SPROUT_CLIENT_SECRET=
SPROUT_ORG_ID=
#
# Option B — Sign in with Sprout (best for a person)
#   Set ONLY SPROUT_CLIENT_ID above (no secret — the flow uses PKCE), then run:
#     npm run login
#   You sign in at Sprout's real login page; the session is saved to
#   ~/.sprout-mcp-auth.json and refreshed automatically.

# Optional: Override auto-discovered customer ID (only for multi-customer setups)
SPROUT_CUSTOMER_ID=
