{
  "name": "@oliverames/sprout-mcp-server",
  "version": "1.1.2",
  "description": "MCP server for Sprout Social API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sprout-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "sprout-social",
    "social-media",
    "analytics",
    "model-context-protocol"
  ],
  "author": "Oliver Ames",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliverames/sprout-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
